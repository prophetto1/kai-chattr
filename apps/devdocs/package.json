{
  "name": "@kai-chattr/devdocs",
  "private": true,
  "version": "0.0.0",
  "description": "kai-chattr docs (fumadocs, static export)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "generate:mdx": "fumadocs-mdx",
    "predev": "pnpm run generate:mdx",
    "prebuild": "pnpm run generate:mdx",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation NEXT_PUBLIC_DOCS_URL=http://localhost:8370 NEXT_PUBLIC_KAI_CHATTR_WEB_URL=http://localhost:8360 next dev -p 8370 -H 0.0.0.0",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 8370 -H 0.0.0.0"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "cross-env": "^7.0.3",
    "fumadocs-core": "^16.9.0",
    "fumadocs-mdx": "^15.0.7",
    "fumadocs-ui": "^16.9.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "remark-directive": "^4.0.0",
    "shiki": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "5.7.3",
    "wrangler": "^4.40.0"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
