{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kai-chattr.local/schemas/design-system.schema.json",
  "title": "Kai Chattr Design System Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "fontFamilies", "typography"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "fontFamilies": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/fontFamily"
      },
      "required": ["ui", "display", "mono"]
    },
    "typography": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roles"],
      "properties": {
        "roles": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/typographyRole"
          }
        }
      }
    }
  },
  "$defs": {
    "cssLength": {
      "type": "string",
      "pattern": "^-?\\\\d+(\\\\.\\\\d+)?(px|rem|em|%)$"
    },
    "fontFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cssVariable", "stack", "purpose"],
      "properties": {
        "cssVariable": {
          "type": "string",
          "pattern": "^--[a-z0-9-]+$"
        },
        "stack": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "default": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "label", "stack"],
            "properties": {
              "value": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 },
              "stack": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "typographyRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fontFamily", "fontSize", "lineHeight", "fontWeight"],
      "properties": {
        "fontFamily": {
          "type": "string",
          "minLength": 1
        },
        "fontSize": {
          "$ref": "#/$defs/cssLength"
        },
        "lineHeight": {
          "$ref": "#/$defs/cssLength"
        },
        "fontWeight": {
          "type": "integer",
          "minimum": 100,
          "maximum": 900
        },
        "selectedFontWeight": {
          "type": "integer",
          "minimum": 100,
          "maximum": 900
        },
        "rowHeight": {
          "$ref": "#/$defs/cssLength"
        },
        "letterSpacing": {
          "oneOf": [
            {
              "const": "normal"
            },
            {
              "$ref": "#/$defs/cssLength"
            },
            {
              "type": "string",
              "pattern": "^-?\\\\d+(\\\\.\\\\d+)?em$"
            }
          ]
        },
        "textTransform": {
          "type": "string",
          "enum": ["none", "uppercase", "lowercase", "capitalize"]
        },
        "fontVariantNumeric": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        }
      }
    }
  }
}
