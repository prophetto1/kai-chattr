_references/

# Runtime-owned SQLite + data dirs (services/api owns its DB; never committed)
data/
*.sqlite3

# MCP capture artifacts (machine-generated console/page dumps)
.playwright-mcp/

# Playwright test artifacts
tests/test-results/
playwright-report/

# Brainstorming visual-companion scratch (mockups regenerated per session)
.superpowers/

# Session scratch screenshots (regenerated per session, not project history)
docs/images/scratch/

# Local planning/reference docs and screenshots stay machine-local.
docs/
!apps/web/functions/docs/
!apps/web/functions/docs/**

# Python tooling caches & coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/

# Monorepo / editor
.turbo/

# Operator-local service config — holds local overrides/secrets (*.local does not match *.toml; keep the .example tracked)
*.local.toml

# Agent session memory/handoffs are machine-local, never published.
.remember/
