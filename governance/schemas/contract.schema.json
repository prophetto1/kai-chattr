{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blockdata.run/schemas/governance-contract.json",
  "title": "Governance contract",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "title", "status", "summary", "covers", "rules", "enforcedBy"],
  "properties": {
    "$comment": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "enum": ["locked", "drafting", "planned", "elsewhere"] },
    "summary": { "type": "string", "minLength": 1 },
    "covers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "rules": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "text"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "locked": { "type": "boolean" },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    },
    "enforcedBy": { "type": "string", "minLength": 1 },
    "enforcement": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "openItems": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "$comment": "Non-planned contracts must declare >=1 rule; status:planned contracts may be rule-less until their slice lands.",
      "if": { "properties": { "status": { "not": { "const": "planned" } } } },
      "then": { "properties": { "rules": { "type": "array", "minItems": 1 } } }
    }
  ]
}
