{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blockdata.run/schemas/governance-registry.json",
  "title": "Governance registry",
  "type": "object",
  "additionalProperties": true,
  "required": ["categories"],
  "properties": {
    "$comment": { "type": "string" },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "contracts"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "contracts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "title", "status", "enforcedBy", "page"],
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
                "title": { "type": "string", "minLength": 1 },
                "status": { "enum": ["locked", "drafting", "planned", "elsewhere"] },
                "enforcedBy": { "type": "string", "minLength": 1 },
                "page": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
